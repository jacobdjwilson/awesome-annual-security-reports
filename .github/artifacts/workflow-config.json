{
  "workflow": {
    "discovery": {
      "default_limit": 10,
      "max_searches_per_run": 12,
      "rotation_days": {
        "_comment": "How often each priority tier is re-searched. The slot scheduler uses these periods to distribute series evenly across time without any database. Adjust to taste — larger values = less frequent searches per series.",
        "current": 30,
        "stale": 91,
        "old": 182
    },
    "conversion": {
      "system_packages": [
        "poppler-utils",
        "tesseract-ocr",
        "libtesseract-dev",
        "libleptonica-dev"
      ],
      "python_packages": [
        "markitdown[pdf,ocr]",
        "pypdf[crypto]",
        "google-genai",
        "google-ai-generativelanguage",
        "Pillow",
        "pytesseract"
      ],
      "max_age_days": 90,
      "min_text_length": 100,
      "max_pdf_chars": 500000,
      "max_polish_input_chars": 60000,
      "prompt_path": ".github/ai-prompts/pdf-to-markdown-prompt.md"
    },
    "pull_request": {
      "branch_prefix": "security-reports-update-",
      "labels": [
        "automated",
        "security-reports"
      ],
      "delete_branch": true,
      "single_report_title_template": "Add {organization} {title} ({year})",
      "multiple_report_title_template": "Update Security Reports - {count} Report(s)"
    },
    "validation": {
      "min_json_size_bytes": 10,
      "validate_toc": true,
      "verify_conversions": true
    },
    "analysis": {
      "python_packages": [
        "google-genai",
        "google-ai-generativelanguage"
      ],
      "markdown_lines_for_analysis": 200,
      "markdown_max_chars_for_analysis": 12000,
      "errors_output_file": "analysis_errors.json",
      "comment": "markdown_lines_for_analysis and markdown_max_chars_for_analysis both apply — the larger resulting slice is used, capped at markdown_max_chars_for_analysis. This ensures enough context is passed even when early lines are sparse (e.g. heavy TOC). errors_output_file names the structured per-report error log emitted when analysis fails."
    },
    "google_search": {
      "python_packages": [
        "requests"
      ]
    },
    "folders": {
      "pdf_source": "Annual Security Reports",
      "markdown_conversions": "Markdown Conversions"
    },
    "virustotal": {
      "api_base_url": "https://www.virustotal.com/api/v3",
      "user_agent": "VirusTotal GitHub Action",
      "large_file_threshold_mb": 32,
      "poll_attempts": 5,
      "poll_backoff_base_seconds": 10,
      "rate_limit_sleep_seconds": 15,
      "skip_on_schedule": false,
      "skip_on_push": false,
      "python_packages": [
        "requests"
      ]
    }
  }
}